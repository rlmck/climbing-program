# Copy to .env (never commit .env). Values come from your Supabase project:
# Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only needed if the GitHub repo is not named "climbing-program"
# (must match the Pages subpath, with leading and trailing slash)
# VITE_BASE=/your-repo-name/
